---
export interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`hero__scene ${className}`}>
  <video
    class="hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/images/posters/godstudio_hero_new_poster.webp"
  >
    <source src="/video/godstudio_hero_new.mp4" type="video/mp4" />
  </video>
</div>

<style>
  .hero__scene {
    position: relative;
    width: 100%;
    height: clamp(420px, 62dvh, 680px);
    border-bottom: 1px solid var(--rule);
    background: #000;
    overflow: hidden;
  }
  .hero__scene--case {
    position: absolute;
    inset: 0;
    height: 100%;
    border-bottom: none;
  }
  @media (max-width: 720px) {
    .hero__scene { height: clamp(360px, 52dvh, 480px); }
    .hero__scene--case {
      position: relative;
      height: clamp(300px, 70vw, 480px);
    }
  }
  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
