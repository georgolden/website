---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { t, type Lang } from '../i18n/translations';
import '../styles/tokens.css';

export interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
}

const { title, description, canonicalURL, ogImage = '/og-image.jpg' } = Astro.props;
const lang = (Astro.currentLocale || 'en') as Lang;
const siteURL = 'https://gostudio.dev';
const resolvedCanonical = canonicalURL ? `${siteURL}${canonicalURL}` : siteURL;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={resolvedCanonical} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteURL}${ogImage}`} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:site_name" content="GO Studio" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://api.fontshare.com" />
  <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
  <link
    href="https://api.fontshare.com/v2/css?f[]=satoshi@700,900&f[]=switzer@400,500,600&display=swap"
    rel="stylesheet"
  />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;600;700;900&display=swap"
    rel="stylesheet"
  />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'GO Studio',
    url: siteURL,
    description: 'Full-stack systems, built and operated by AI.',
    founder: { '@type': 'Person', name: 'Georg Oldenburger' },
  })} />
</head>

<body>
  <a href="#main-content" class="skip-link">{t(lang, 'skip')}</a>

  <Nav />

  <main id="main-content">
    <slot />
  </main>

  <Footer />

  <!-- SVG distortion filter for liquid-glass lens effect -->
  <svg width="0" height="0" style="position:absolute;overflow:hidden;" aria-hidden="true">
    <defs>
      <filter id="cursor-glass" x="-20%" y="-20%" width="140%" height="140%">
        <feTurbulence type="fractalNoise" baseFrequency="0.035 0.035"
          numOctaves="2" seed="42" result="noise" />
        <feGaussianBlur in="noise" stdDeviation="0.5" result="blurred" />
        <feDisplacementMap in="SourceGraphic" in2="blurred"
          scale="5" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
  </svg>

  <!-- Liquid-glass cursor bubble -->
  <div id="glass-cursor" aria-hidden="true">
    <span class="gc-lens"></span>
    <span class="gc-ring"></span>
    <span class="gc-shine"></span>
  </div>
</body>
</html>


<script>
  (function () {
    if (!window.matchMedia('(hover: hover)').matches) return;

    const el = document.getElementById('glass-cursor');
    if (!el) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let mx = 0, my = 0, cx = 0, cy = 0;
    let started = false;

    document.addEventListener('mousemove', (e) => {
      mx = e.clientX;
      my = e.clientY;
      if (!started) {
        cx = mx; cy = my;
        started = true;
        el.classList.add('is-visible');
      }
    }, { passive: true });

    document.addEventListener('mouseleave', () => el.classList.remove('is-visible'));
    document.addEventListener('mouseenter', () => { if (started) el.classList.add('is-visible'); });

    document.addEventListener('mouseover', (e) => {
      const t = e.target as Element;
      if (t.closest('a, button, [role="button"], input, textarea, select, label')) {
        el.classList.add('is-hover');
      } else {
        el.classList.remove('is-hover');
      }
    });

    document.addEventListener('mousedown', () => el.classList.add('is-click'));
    document.addEventListener('mouseup',   () => el.classList.remove('is-click'));

    // Spring lerp — faster factor when reduced-motion to avoid vestibular issues
    // but never instant-snap so it always feels physically connected to the cursor
    const lerp = reduced ? 0.40 : 0.11;

    function tick() {
      cx += (mx - cx) * lerp;
      cy += (my - cy) * lerp;
      const hw = el.offsetWidth  / 2;
      const hh = el.offsetHeight / 2;
      el.style.transform = `translate(${cx - hw}px, ${cy - hh}px)`;
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  })();
</script>
