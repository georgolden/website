---
import BaseLayout from '../layouts/BaseLayout.astro';
import AgentCard from '../components/AgentCard.astro';
import { t, type Lang } from '../i18n/translations';

const lang = (Astro.currentLocale || 'en') as Lang;

const introMeta = [
  { key: 'Practice',      val: '10+ years' },
  { key: 'Based',         val: 'EU, remote' },
  { key: 'Live projects', val: '2 · operated' },
  { key: 'Mode',          val: 'Built & run' },
];

const webRows = [
  { id: 'websites', title: t(lang, 'svc.01.title'), desc: t(lang, 'svc.01.copy') },
  { id: 'hosting',  title: t(lang, 'svc.02.title'), desc: t(lang, 'svc.02.copy') },
  { id: 'seo',      title: t(lang, 'svc.03.title'), desc: t(lang, 'svc.03.copy') },
  { id: 'ai-web',   title: t(lang, 'svc.04.title'), desc: t(lang, 'svc.04.copy') },
];
const productRows = [
  { id: 'mvp',        title: t(lang, 'svc.05.title'), desc: t(lang, 'svc.05.copy') },
  { id: 'product',    title: t(lang, 'svc.06.title'), desc: t(lang, 'svc.06.copy') },
  { id: 'ai-product', title: t(lang, 'svc.07.title'), desc: t(lang, 'svc.07.copy') },
];

const numbers = [
  { metric: '20K+', label: t(lang, 'about.numbers.traders') },
  { metric: '20TB', label: t(lang, 'about.numbers.data') },
  { metric: '10K+', label: t(lang, 'about.numbers.workers') },
  { metric: '0',    label: t(lang, 'about.numbers.uptime') },
];

const agentHints = [
  t(lang, 'about.agent.hint.1'),
  t(lang, 'about.agent.hint.2'),
  t(lang, 'about.agent.hint.3'),
  t(lang, 'about.agent.hint.4'),
];
---

<BaseLayout
  title="About — GO Studio"
  description="A small EU-based team building complete digital systems. Built and operated."
  canonicalURL="/about/"
>
  <!-- 01 Intro -->
  <section class="intro intro--tight">
    <div class="shell">
      <p class="intro__eyebrow">{t(lang, 'about.eyebrow')}</p>
      <h1 class="intro__name">{t(lang, 'about.name')}</h1>

      <div class="intro__body">
        <dl class="intro__meta">
          {introMeta.map(m => (
            <div class="intro__meta-row">
              <p class="intro__meta-key">{m.key}</p>
              <p class="intro__meta-val">{m.val}</p>
            </div>
          ))}
        </dl>
        <p class="intro__lede prose">{t(lang, 'about.lede')}</p>
      </div>
    </div>
  </section>

  <!-- 02 Capabilities -->
  <section class="caps">
    <div class="shell">

      <div class="work-cat">
        <p class="work-cat__eyebrow">{t(lang, 'about.web.eyebrow')}</p>
        <h2 class="work-cat__mark">{t(lang, 'about.web.mark')}</h2>
        <div class="work-list">
          {webRows.map(r => (
            <div class="work-row" id={r.id}>
              <h4 class="work-row__title">{r.title}</h4>
              <p class="work-row__desc">{r.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="work-cat">
        <p class="work-cat__eyebrow">{t(lang, 'about.product.eyebrow')}</p>
        <h2 class="work-cat__mark">{t(lang, 'about.product.mark')}</h2>
        <div class="work-list">
          <div class="work-row" id={productRows[0].id}>
            <h4 class="work-row__title">{productRows[0].title}</h4>
            <p class="work-row__desc">{productRows[0].desc}</p>
          </div>
          <div class="mvp-pair">
            <div>
              <p class="mvp-pair__when">{t(lang, 'about.mvp.pre')}</p>
              <p class="mvp-pair__metric">6 mo</p>
              <p class="mvp-pair__what">{t(lang, 'about.mvp.pre.what')}</p>
            </div>
            <div>
              <p class="mvp-pair__when">{t(lang, 'about.mvp.post')}</p>
              <p class="mvp-pair__metric">4 mo</p>
              <p class="mvp-pair__what">{t(lang, 'about.mvp.post.what')}</p>
            </div>
          </div>
          {productRows.slice(1).map(r => (
            <div class="work-row" id={r.id}>
              <h4 class="work-row__title">{r.title}</h4>
              <p class="work-row__desc">{r.desc}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- 03 Numbers -->
  <section class="ach">
    <div class="shell">
      <header class="ach__head">
        <div>
          <p class="section-label">{t(lang, 'about.numbers.label')}</p>
          <h2 class="ach__title">{t(lang, 'about.numbers.title')}</h2>
        </div>
      </header>

      <div class="numbers">
        {numbers.map(n => (
          <div class="numbers__cell">
            <p class="numbers__metric">{n.metric}</p>
            <p class="numbers__label">{n.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 04 Founder -->
  <section class="founder">
    <div class="shell">
      <header class="founder__head">
        <div>
          <p class="section-label">{t(lang, 'about.founder.label')}</p>
          <h2 class="founder__title">{t(lang, 'about.founder.title')}</h2>
        </div>
        <p class="founder__lede prose">{t(lang, 'about.founder.lede')}</p>
      </header>

      <div class="founder__body">
        <div class="ph founder__photo">[ Portrait · 4:5 ]</div>
        <div class="prose">
          <p class="founder__name">{t(lang, 'about.founder.name')}</p>
          <p class="founder__role">{t(lang, 'about.founder.role')}</p>
          <p>{t(lang, 'about.founder.p1')}</p>
          <p>{t(lang, 'about.founder.p2')}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 05 Agent -->
  <section class="agent">
    <div class="agent__motif" aria-hidden="true">
      <svg viewBox="0 0 1440 600" fill="none" stroke="currentColor" stroke-width="1" preserveAspectRatio="xMidYMid slice">
        <path d="M-100,520 C200,460 360,560 600,500 C840,440 980,540 1200,470 C1380,415 1500,460 1600,440"/>
        <path d="M-100,460 C200,400 380,500 620,440 C860,380 1000,480 1220,410 C1390,355 1500,400 1600,380"/>
        <path d="M-100,400 C200,340 400,440 640,380 C880,320 1020,420 1240,350 C1400,295 1500,340 1600,320"/>
        <path d="M-100,340 C200,280 420,380 660,320 C900,260 1040,360 1260,290 C1410,235 1500,280 1600,260"/>
        <path d="M-100,280 C200,220 440,320 680,260 C920,200 1060,300 1280,230 C1420,175 1500,220 1600,200"/>
        <path d="M-100,220 C200,160 460,260 700,200 C940,140 1080,240 1300,170 C1430,115 1500,160 1600,140"/>
        <path d="M-100,160 C200,100 480,200 720,140 C960,80 1100,180 1320,110 C1440,55 1500,100 1600,80"/>
        <path d="M-100,100 C200,40 500,140 740,80 C980,20 1120,120 1340,50 C1450,-5 1500,40 1600,20"/>
      </svg>
    </div>
    <div class="shell">
      <AgentCard
        eyebrow={t(lang, 'about.agent.eyebrow')}
        title={t(lang, 'about.agent.title')}
        lede={t(lang, 'about.agent.lede')}
        placeholder={t(lang, 'about.agent.placeholder')}
        ariaLabel={t(lang, 'opener.input.aria')}
        hints={agentHints}
        inputVariant="surface"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    padding-top: clamp(8rem, 14vw, 13rem);
    padding-bottom: clamp(4rem, 7vw, 6rem);
  }
  .intro--tight { padding-bottom: clamp(2rem, 4vw, 3rem); }
  .intro__eyebrow {
    font-family: var(--mono); font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 clamp(2rem, 4vw, 3rem);
  }
  .intro__name {
    font-family: var(--display); font-weight: 900;
    font-size: clamp(1.75rem, 1.2rem + 2.5vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
    margin: 0; max-width: 22ch;
  }
  .intro__body {
    margin-top: clamp(2rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
    padding-top: clamp(1.5rem, 3vw, 2.25rem);
    border-top: 1px solid var(--rule);
  }
  .intro__meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem 1.5rem;
    margin: 0;
  }
  .intro__meta-row { display: block; }
  .intro__meta-key {
    font-family: var(--mono); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0;
    padding-bottom: 0.25rem;
  }
  .intro__meta-val {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(1.25rem, 1rem + 0.8vw, 1.75rem);
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0; line-height: 1.1;
  }
  .intro__lede {
    margin: 0;
    font-size: var(--step-2);
    color: var(--ink-soft);
    max-width: 65ch;
  }
  @media (max-width: 720px) {
    .intro__body { grid-template-columns: 1fr; padding-top: 2rem; }
  }

  .caps { padding-block: 0; }
  .work-cat {
    padding-block: clamp(2rem, 4vw, 3.5rem);
    border-top: 1px solid var(--rule);
  }
  .work-cat__eyebrow {
    font-family: var(--mono); font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 0.5rem;
  }
  .work-cat__mark {
    font-family: var(--display); font-weight: 900;
    font-size: clamp(1.75rem, 1.2rem + 2.5vw, 3rem);
    letter-spacing: -0.025em;
    line-height: 0.98;
    margin: 0 0 clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .work-list { border-top: 1px solid var(--rule); }
  .work-row {
    display: grid;
    grid-template-columns: minmax(180px, 1fr) minmax(0, 2fr);
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: baseline;
    padding-block: clamp(0.85rem, 1.5vw, 1.1rem);
    border-bottom: 1px solid var(--rule);
  }
  .work-row__title {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.25rem);
    letter-spacing: -0.015em;
    margin: 0; line-height: 1.2;
  }
  .work-row__desc {
    margin: 0; color: var(--ink-soft);
    font-size: var(--step-1);
    line-height: 1.45;
    max-width: 60ch;
  }
  @media (max-width: 640px) {
    .work-row { grid-template-columns: 1fr; gap: 0.2rem; }
  }

  .mvp-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding-block: clamp(0.85rem, 1.5vw, 1.1rem);
    border-bottom: 1px solid var(--rule);
  }
  .mvp-pair > div { padding: 0 clamp(1rem, 2vw, 1.5rem); }
  .mvp-pair > div + div { border-left: 1px solid var(--rule); }
  .mvp-pair__when {
    font-family: var(--mono); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 0.5rem;
  }
  .mvp-pair__metric {
    font-family: var(--display); font-weight: 900;
    font-size: clamp(2rem, 1.5rem + 2vw, 3rem);
    letter-spacing: -0.025em;
    line-height: 0.95;
    margin: 0 0 0.25rem;
  }
  .mvp-pair__what {
    margin: 0; font-size: var(--step-1); color: var(--ink-soft);
    line-height: 1.35;
  }
  @media (max-width: 640px) {
    .mvp-pair { grid-template-columns: 1fr; }
    .mvp-pair > div + div { border-left: 0; border-top: 1px solid var(--rule); padding-top: 1rem; margin-top: 0.5rem; }
  }

  .ach {
    padding-block: clamp(3rem, 5vw, 4rem);
    border-top: 1px solid var(--rule);
  }
  .ach__head {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: end;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .ach__title {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.018em;
    margin: 0.4rem 0 0;
    max-width: 22ch;
    color: var(--ink);
  }
  @media (max-width: 720px) {
    .ach__head { grid-template-columns: 1fr; gap: 0.35rem; }
  }
  .numbers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
  }
  .numbers__cell {
    background: var(--bg);
    padding: clamp(2rem, 4vw, 3.5rem);
    display: grid;
    grid-template-rows: 1fr auto;
    min-height: clamp(180px, 22vw, 280px);
  }
  .numbers__metric {
    font-family: var(--display); font-weight: 900;
    font-size: clamp(2.75rem, 2rem + 4vw, 5.5rem);
    letter-spacing: -0.035em;
    line-height: 0.92;
    margin: 0;
    align-self: end;
  }
  .numbers__label {
    margin: 1.25rem 0 0;
    font-size: var(--step-1);
    color: var(--ink-soft);
    max-width: 32ch;
  }
  @media (max-width: 640px) {
    .numbers { grid-template-columns: 1fr; }
  }

  .founder { padding-block: clamp(3rem, 5vw, 4rem); border-top: 1px solid var(--rule); }
  .founder__head {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: end;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .founder__title {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2.5rem);
    line-height: 1.08;
    letter-spacing: -0.018em;
    margin: 0.4rem 0 0;
    max-width: 22ch;
  }
  .founder__lede { color: var(--ink-soft); margin: 0; max-width: 50ch; }
  .founder__body {
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(0, 9fr);
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }
  .founder__photo { aspect-ratio: 4 / 5; border-radius: 6px; }
  .founder__name {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(1.25rem, 1rem + 0.8vw, 1.75rem);
    letter-spacing: -0.015em;
    margin: 0 0 0.25rem;
    color: var(--ink);
  }
  .founder__role {
    font-family: var(--mono); font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 1.25rem;
  }
  @media (max-width: 720px) {
    .founder__head, .founder__body { grid-template-columns: 1fr; }
    .founder__photo { max-width: 60%; }
  }

  .agent {
    position: relative;
    padding-block: clamp(3rem, 5vw, 4rem) clamp(5rem, 9vw, 8rem);
    border-top: 1px solid var(--rule-soft);
    overflow: hidden;
  }
  .agent__motif {
    position: absolute; inset: 0; z-index: 0;
    color: var(--ink); opacity: 0.035;
    pointer-events: none;
  }
  .agent__motif svg { width: 100%; height: 100%; display: block; }
  .agent .shell { position: relative; z-index: 1; }
</style>
