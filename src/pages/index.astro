---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroScene from '../components/HeroScene.astro';
import WorkCard from '../components/WorkCard.astro';
import ServiceRow from '../components/ServiceRow.astro';
import AgentCard from '../components/AgentCard.astro';
import { t, type Lang } from '../i18n/translations';

const lang = (Astro.currentLocale || 'en') as Lang;

const work = [
  {
    href: '/work/resonance',
    name: 'Resonance Vision',
    description: 'Real-time trading platform. 20TB+ ingestion, custom analytics engine.',
    tags: ['SaaS', 'Backend', 'Real-time'],
    mediaLabel: '[ video loop · trading dashboard ]',
    variant: 'lead' as const,
  },
  {
    href: '/work/44pool',
    name: '44pool',
    description: 'Distributed mining pool. Worldwide infrastructure, multi-coin payouts.',
    tags: ['Infrastructure', 'Backend', 'Distributed'],
    mediaLabel: '[ video loop · mining pool ops ]',
    image: '/images/main_44pool.webp',
    variant: 'offset' as const,
  },
];

const serviceSpecs: { slug: string; caps: number }[] = [
  { slug: 'websites',  caps: 2 },
  { slug: 'hosting',   caps: 2 },
  { slug: 'seo',       caps: 1 },
  { slug: 'ai-web',    caps: 1 },
  { slug: 'mvp',       caps: 1 },
  { slug: 'product',   caps: 1 },
  { slug: 'ai-product',caps: 1 },
];

const services = serviceSpecs.map((spec, i) => {
  const n = String(i + 1).padStart(2, '0');
  return {
    num: n,
    title: t(lang, `svc.${n}.title`),
    copy: t(lang, `svc.${n}.copy`),
    capabilities: Array.from({ length: spec.caps }, (_, j) => t(lang, `svc.${n}.cap${j + 1}`)),
    href: `/about/#${spec.slug}`,
  };
});

const openerHints = [
  t(lang, 'opener.hint.1'),
  t(lang, 'opener.hint.2'),
  t(lang, 'opener.hint.3'),
  t(lang, 'opener.hint.4'),
];

const gapStudios = ['Pretty pages', 'WordPress, Webflow, Shopify', 'Maybe a CMS', '"Talk to your backend team"', 'Project closed at launch'];
const gapUs = ['Websites and SaaS UI', 'Backend infrastructure we own', 'AI woven in, not stapled on', 'Hosted, monitored, kept fast', 'One contact, end to end'];
---

<BaseLayout
  title="GO Studio — Full-stack systems, built and operated by AI"
  description="Websites, SaaS platforms, backend infrastructure, AI agents. One studio."
>
  <!-- HERO -->
  <section class="hero" data-nav-theme="white">
    <HeroScene />
    <div class="hero__content shell">
      <h1 class="hero__title">{t(lang, 'hero.title')}</h1>
      <p class="hero__sub">{t(lang, 'hero.sub')}</p>
    </div>
  </section>

  <!-- WORK -->
  <section class="section">
    <div class="shell">
      <header class="section__head">
        <div>
          <p class="section-label">{t(lang, 'work.label')}</p>
          <h2 class="section__title">{t(lang, 'work.title')}</h2>
        </div>
        <a href="/work/" class="section__link">{t(lang, 'work.viewAll')}</a>
      </header>

      <div class="work-grid work-grid--paired">
        {work.map(w => <WorkCard {...w} />)}
      </div>
    </div>
  </section>

  <!-- VALUE GAP -->
  <section class="gap">
    <div class="shell">
      <header class="section__head">
        <div>
          <p class="section-label">The gap</p>
          <h2 class="section__title">Most studios stop halfway.</h2>
        </div>
      </header>

      <div class="gap__grid">
        <div class="gap__col">
          <p class="gap__label">What most studios ship</p>
          <h3 class="gap__headline">Design, build, hand off.</h3>
          <ul class="gap__list">
            {gapStudios.map(i => <li>{i}</li>)}
          </ul>
        </div>
        <div class="gap__col gap__col--us">
          <p class="gap__label">What we ship</p>
          <h3 class="gap__headline">The whole system, operated.</h3>
          <ul class="gap__list">
            {gapUs.map(i => <li>{i}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section section--to-opener">
    <div class="shell">
      <header class="section__head">
        <div>
          <p class="section-label">{t(lang, 'svc.label')}</p>
          <h2 class="section__title">{t(lang, 'svc.title')}</h2>
        </div>
      </header>

      <div class="services">
        {services.map(s => <ServiceRow {...s} />)}
      </div>
    </div>
  </section>

  <!-- OPENER -->
  <section class="opener-section">
    <div class="opener-section__motif" aria-hidden="true">
      <svg viewBox="0 0 1440 600" fill="none" stroke="currentColor" stroke-width="1" preserveAspectRatio="xMidYMid slice">
        <path d="M-100,520 C200,460 360,560 600,500 C840,440 980,540 1200,470 C1380,415 1500,460 1600,440"/>
        <path d="M-100,460 C200,400 380,500 620,440 C860,380 1000,480 1220,410 C1390,355 1500,400 1600,380"/>
        <path d="M-100,400 C200,340 400,440 640,380 C880,320 1020,420 1240,350 C1400,295 1500,340 1600,320"/>
        <path d="M-100,340 C200,280 420,380 660,320 C900,260 1040,360 1260,290 C1410,235 1500,280 1600,260"/>
        <path d="M-100,280 C200,220 440,320 680,260 C920,200 1060,300 1280,230 C1420,175 1500,220 1600,200"/>
        <path d="M-100,220 C200,160 460,260 700,200 C940,140 1080,240 1300,170 C1430,115 1500,160 1600,140"/>
        <path d="M-100,160 C200,100 480,200 720,140 C960,80 1100,180 1320,110 C1440,55 1500,100 1600,80"/>
        <path d="M-100,100 C200,40 500,140 740,80 C980,20 1120,120 1340,50 C1450,-5 1500,40 1600,20"/>
      </svg>
    </div>
    <div class="shell">
      <AgentCard
        eyebrow={t(lang, 'opener.eyebrow')}
        title={t(lang, 'opener.title')}
        lede={t(lang, 'opener.lede')}
        placeholder={t(lang, 'opener.input.placeholder')}
        ariaLabel={t(lang, 'opener.input.aria')}
        hints={openerHints}
        inputVariant="surface"
      />
    </div>
  </section>
  <script is:inline>
    (() => {
      if (window.__navInverter) window.__navInverter.disconnect();
      document.body.classList.remove("nav-white");

      const recompute = () => {
        const el = document.elementFromPoint(10, 80);
        const section = el?.closest('[data-nav-theme]');
        const white = section ? section.dataset.navTheme === "white" : false;
        document.body.classList.toggle("nav-white", white);
      };

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => { recompute(); ticking = false; });
          ticking = true;
        }
      }, { passive: true });

      const obs = new IntersectionObserver(() => recompute(),
        { rootMargin: "-65px 0px 0px 0px", threshold: 0 });

      document.querySelectorAll("[data-nav-theme]").forEach((el) => obs.observe(el));
      window.__navInverter = obs;

      window.addEventListener("pageshow", (e) => { if (e.persisted) recompute(); });
      recompute();
    })();
  </script>
</BaseLayout>

<style>
  .hero { padding-block: 0 clamp(3rem, 5vw, 5rem); }
  .hero__content {
    max-width: 1080px;
    margin: clamp(1.5rem, 3vw, 2rem) auto 0;
  }
  .hero__title {
    font-family: var(--display);
    font-weight: 900;
    font-size: clamp(1.75rem, 1.2rem + 2.5vw, 3rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
    max-width: 22ch;
    text-wrap: balance;
  }
  .hero__sub {
    font-size: var(--step-2);
    color: var(--ink-soft);
    line-height: 1.35;
    max-width: 50ch;
    margin: 0;
  }

  .section {
    padding-block: clamp(4rem, 7vw, 7rem);
    border-top: 1px solid var(--rule-soft);
  }
  .section--to-opener { padding-bottom: 0; }
  .section__head {
    display: flex; align-items: end; justify-content: space-between;
    gap: 2rem;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }
  .section__title {
    font-family: var(--display); font-weight: 700;
    font-size: var(--step-3); letter-spacing: -0.02em;
    margin: 0.5rem 0 0;
    line-height: 1.05;
  }
  .section__link {
    font-size: var(--step-1);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    white-space: nowrap;
  }


  .services { display: grid; grid-template-columns: 1fr; }

  /* Value gap */
  .gap {
    padding-block: clamp(4rem, 7vw, 7rem);
    border-top: 1px solid var(--rule-soft);
  }
  .gap__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    margin-top: clamp(2rem, 4vw, 3rem);
  }
  .gap__col {
    display: flex; flex-direction: column;
    padding-top: 1.25rem;
    border-top: 1px solid var(--rule);
  }
  .gap__col--us { border-top-color: var(--ink); }
  .gap__label {
    font-family: var(--mono);
    font-size: 0.75rem;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: var(--ink-mute);
    margin: 0 0 1rem;
  }
  .gap__col--us .gap__label { color: var(--ink); }
  .gap__headline {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(1.5rem, 1.1rem + 1.5vw, 2.25rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    max-width: 18ch;
  }
  .gap__list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.55rem; }
  .gap__list li {
    display: grid;
    grid-template-columns: 1.25rem 1fr;
    align-items: baseline;
    gap: 0.5rem;
    font-size: var(--step-0);
    color: var(--ink-soft);
  }
  .gap__list li::before {
    content: ""; display: block;
    height: 1px; width: 12px;
    background: currentColor;
    transform: translateY(-0.4em);
  }
  .gap__col--us .gap__list li { color: var(--ink); }
  @media (max-width: 720px) {
    .gap__grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  /* Opener band with topographic motif */
  .opener-section {
    position: relative;
    background: var(--bg);
    border-top: 1px solid var(--rule-soft);
    overflow: hidden;
  }
  .opener-section__motif {
    position: absolute; inset: 0; z-index: 0;
    color: var(--ink); opacity: 0.035;
    pointer-events: none;
  }
  .opener-section__motif svg { width: 100%; height: 100%; display: block; }
  .opener-section .shell { position: relative; z-index: 1; }
</style>
