---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgentCard from '../../components/AgentCard.astro';
import { t, type Lang } from '../../i18n/translations';
import '../../styles/case.css';

const lang = (Astro.currentLocale || 'en') as Lang;

const meta = [
  { key: t(lang, 'case.meta.year'),     val: '2024 — present' },
  { key: t(lang, 'case.meta.industry'), val: 'Trading · Fintech' },
  { key: 'Traders',                      val: '20,000+ active' },
  { key: t(lang, 'case.meta.scale'),     val: '20TB / month' },
];

const stats = [
  { key: 'Tick to chart',   val: '<200ms' },
  { key: 'Historical data', val: '20+TB' },
  { key: 'Active traders',  val: '20,000+' },
  { key: 'Live feeds',      val: '9 exchanges' },
];

const hints = [
  'What was the hardest part?',
  'How is uptime measured?',
  'Could you build this for me?',
  'What did this cost?',
];
---

<BaseLayout
  title="Resonance Vision — Case study · GO Studio"
  description="Real-time trading platform. Nine exchanges, one chart, zero lag."
  canonicalURL="/work/resonance/"
>
  <!-- 01 Client -->
  <section class="intro">
    <div class="shell">
      <p class="intro__eyebrow">{t(lang, 'case.client')}</p>
      <h1 class="intro__client">Resonance Vision</h1>

      <div class="intro__body">
        <dl class="intro__meta">
          {meta.map(m => (
            <div class="intro__meta-row">
              <p class="intro__meta-key">{m.key}</p>
              <p class="intro__meta-val">{m.val}</p>
            </div>
          ))}
        </dl>

        <div class="prose">
          <p>Resonance Vision is a real-time trading platform serving retail and institutional traders. Institutional-grade ingestion behind a UI a retail trader can read in a glance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 02 Challenge -->
  <section class="challenge">
    <div class="shell">
      <p class="section-label">{t(lang, 'case.challenge')}</p>
      <h2 class="challenge__title">Nine exchanges, <em>one chart</em>, zero lag — under a single operator.</h2>
      <div class="prose">
        <p>Nine live feeds without dropped messages. Analytics on a stream that doesn't pause. Charts that don't stutter with eight open. Stacked, those break most architectures, and there's one operator running it.</p>
      </div>
    </div>
  </section>

  <!-- 03 Showcase -->
  <section class="showcase">
    <div class="shell showcase__inner">
      <p class="showcase__label">{t(lang, 'case.inMotion')}</p>
      <figure class="showcase__video">
        <div class="showcase__video-bar"><i></i><i></i><i></i></div>
        <div class="ph">[ Dashboard capture · 16:9 video loop ]</div>
      </figure>
      <div class="showcase__phones">
        <div class="phone showcase__m1"><div class="ph">[ Watchlist ]</div></div>
        <div class="phone showcase__m2"><div class="ph">[ Chart detail ]</div></div>
        <div class="phone showcase__m3"><div class="ph">[ Order book ]</div></div>
      </div>
    </div>
  </section>

  <!-- 04 What was done + architecture -->
  <section class="done">
    <div class="shell">
      <div class="done__grid">
        <div>
          <p class="section-label">{t(lang, 'case.whatDone')}</p>
          <h2 class="section-title">Built solo, end to end.</h2>
        </div>
        <div class="prose">
          <p>From the cluster to the chart: ingestion from nine exchanges, analytics engine over a 20+TB historical store, WebSocket fan-out, the trader-facing dashboard, multi-region edge. Built and still operated by one person.</p>
          <p>Real-time charts that hold up with eight open. Queryable history a trader can scroll through years deep. The UI gives a glance, the system does the heavy work behind it.</p>
        </div>
      </div>

      <dl class="stats">
        {stats.map(s => (
          <div>
            <p class="stat-key">{s.key}</p>
            <p class="stat-val">{s.val}</p>
          </div>
        ))}
      </dl>

      <div class="diagram" aria-label="Architecture diagram">
        <svg viewBox="0 0 1200 460" fill="none" stroke="currentColor" stroke-width="1"
             font-family="ui-monospace, JetBrains Mono, monospace" font-size="11"
             preserveAspectRatio="xMidYMid meet">
          <defs>
            <marker id="arrRV" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
              <path d="M0 0 L10 5 L0 10 z" fill="currentColor" stroke="none"/>
            </marker>
          </defs>

          <text x="20"   y="22" fill="currentColor" stroke="none" letter-spacing="2" opacity="0.45">TRADERS</text>
          <text x="600"  y="22" fill="currentColor" stroke="none" letter-spacing="2" opacity="0.45" text-anchor="middle">PLATFORM</text>
          <text x="1040" y="22" fill="currentColor" stroke="none" letter-spacing="2" opacity="0.45" text-anchor="middle">EXCHANGES</text>

          <g stroke-width="1.4">
            <circle cx="40" cy="80"  r="5"/>
            <circle cx="90" cy="110" r="5"/>
            <circle cx="40" cy="140" r="5"/>
            <circle cx="90" cy="170" r="5"/>
            <circle cx="40" cy="200" r="5"/>
            <circle cx="90" cy="230" r="5"/>
            <circle cx="40" cy="260" r="5"/>
            <circle cx="90" cy="290" r="5"/>
            <circle cx="40" cy="320" r="5"/>
            <circle cx="90" cy="350" r="5"/>
          </g>
          <text x="20" y="410" fill="currentColor" stroke="none" opacity="0.7">20,000+ traders</text>

          <g stroke-dasharray="5 5" opacity="0.45">
            <path d="M150 100 C 260 100, 320 110, 420 110"/>
            <path d="M150 180 C 260 180, 320 120, 420 120"/>
            <path d="M150 260 C 260 260, 320 130, 420 130"/>
            <path d="M150 340 C 260 340, 320 140, 420 140"/>
          </g>
          <text x="270" y="80" fill="currentColor" stroke="none" opacity="0.55">traffic →</text>

          <rect x="420" y="80" width="360" height="76" rx="6"/>
          <text x="600" y="112" fill="currentColor" stroke="none" letter-spacing="2" text-anchor="middle">USER API</text>
          <text x="600" y="134" fill="currentColor" stroke="none" opacity="0.55" text-anchor="middle">WebSocket fan-out · dashboard</text>

          <rect x="420" y="190" width="360" height="76" rx="6"/>
          <text x="600" y="222" fill="currentColor" stroke="none" letter-spacing="2" text-anchor="middle">ANALYTICS ENGINE</text>
          <text x="600" y="244" fill="currentColor" stroke="none" opacity="0.55" text-anchor="middle">20+TB queryable history</text>

          <rect x="420" y="300" width="360" height="76" rx="6"/>
          <text x="600" y="332" fill="currentColor" stroke="none" letter-spacing="2" text-anchor="middle">INGESTION</text>
          <text x="600" y="354" fill="currentColor" stroke="none" opacity="0.55" text-anchor="middle">normalize · validate · dedupe</text>

          <path d="M580 156 V 188" marker-end="url(#arrRV)"/>
          <path d="M620 188 V 156" marker-end="url(#arrRV)"/>
          <path d="M580 266 V 298" marker-end="url(#arrRV)"/>
          <path d="M620 298 V 266" marker-end="url(#arrRV)"/>

          <g>
            <rect x="860"  y="80"  width="140" height="56" rx="4"/>
            <text x="930"  y="113" fill="currentColor" stroke="none" text-anchor="middle">BINANCE</text>
            <rect x="1020" y="80"  width="140" height="56" rx="4"/>
            <text x="1090" y="113" fill="currentColor" stroke="none" text-anchor="middle">COINBASE</text>
            <rect x="860"  y="160" width="140" height="56" rx="4"/>
            <text x="930"  y="193" fill="currentColor" stroke="none" text-anchor="middle">KRAKEN</text>
            <rect x="1020" y="160" width="140" height="56" rx="4"/>
            <text x="1090" y="193" fill="currentColor" stroke="none" text-anchor="middle">BYBIT</text>
            <rect x="860"  y="240" width="140" height="56" rx="4"/>
            <text x="930"  y="273" fill="currentColor" stroke="none" text-anchor="middle">OKX</text>
            <rect x="1020" y="240" width="140" height="56" rx="4"/>
            <text x="1090" y="273" fill="currentColor" stroke="none" text-anchor="middle">BITFINEX</text>
            <rect x="860"  y="320" width="300" height="56" rx="4" stroke-dasharray="4 4" opacity="0.55"/>
            <text x="1010" y="353" fill="currentColor" stroke="none" text-anchor="middle" opacity="0.6">+ 3 MORE</text>
          </g>

          <g stroke-dasharray="5 5" opacity="0.45">
            <path d="M860 108 C 820 108, 790 338, 780 338"/>
            <path d="M860 188 C 820 188, 790 340, 780 340"/>
            <path d="M860 268 C 820 268, 790 342, 780 342"/>
            <path d="M860 348 H 780"/>
          </g>
          <text x="800" y="68" fill="currentColor" stroke="none" opacity="0.55">feeds →</text>
        </svg>

        <div class="diagram__mobile">
          <div class="dnode">Traders<small>20,000+ active</small></div>
          <div class="dpipe">traffic ↓</div>
          <div class="dnode">User API<small>WebSocket fan-out · dashboard</small></div>
          <div class="dpipe">↕</div>
          <div class="dnode">Analytics engine<small>20+TB queryable history</small></div>
          <div class="dpipe">↕</div>
          <div class="dnode">Ingestion<small>normalize · validate · dedupe</small></div>
          <div class="dpipe">feeds ↑</div>
          <div class="dgrid">
            <span>Binance</span><span>Coinbase</span>
            <span>Kraken</span><span>Bybit</span>
            <span>OKX</span><span>Bitfinex</span>
            <span class="span2">+ 3 more</span>
          </div>
        </div>
      </div>

      <p class="done__caption">Exchanges feed ingestion → analytics holds history → user API renders the chart</p>
    </div>
  </section>

  <!-- 05 Project agent -->
  <section class="agent">
    <div class="agent__motif" aria-hidden="true">
      <svg viewBox="0 0 1440 600" fill="none" stroke="currentColor" stroke-width="1" preserveAspectRatio="xMidYMid slice">
        <path d="M-100,520 C200,460 360,560 600,500 C840,440 980,540 1200,470 C1380,415 1500,460 1600,440"/>
        <path d="M-100,460 C200,400 380,500 620,440 C860,380 1000,480 1220,410 C1390,355 1500,400 1600,380"/>
        <path d="M-100,400 C200,340 400,440 640,380 C880,320 1020,420 1240,350 C1400,295 1500,340 1600,320"/>
        <path d="M-100,340 C200,280 420,380 660,320 C900,260 1040,360 1260,290 C1410,235 1500,280 1600,260"/>
        <path d="M-100,280 C200,220 440,320 680,260 C920,200 1060,300 1280,230 C1420,175 1500,220 1600,200"/>
        <path d="M-100,220 C200,160 460,260 700,200 C940,140 1080,240 1300,170 C1430,115 1500,160 1600,140"/>
        <path d="M-100,160 C200,100 480,200 720,140 C960,80 1100,180 1320,110 C1440,55 1500,100 1600,80"/>
        <path d="M-100,100 C200,40 500,140 740,80 C980,20 1120,120 1340,50 C1450,-5 1500,40 1600,20"/>
      </svg>
    </div>
    <div class="shell">
      <AgentCard
        eyebrow="Project agent · Resonance Vision"
        title="Ask anything."
        lede="It has the architecture, the constraints, the timeline. It can also talk about building something similar for your business."
        placeholder="How did you handle real-time data?"
        ariaLabel="Ask the project agent"
        hints={hints}
        inputVariant="surface"
      />
    </div>
  </section>

  <section class="next">
    <a href="/work/44pool">
      <p class="next__eyebrow">{t(lang, 'case.next')} — 02 / 02</p>
      <h2 class="next__title">44pool →</h2>
      <span class="next__arrow">Distributed mining pool · worldwide infrastructure</span>
    </a>
  </section>
</BaseLayout>
